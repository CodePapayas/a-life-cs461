{
    "version": 8,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default GCC Debug",
            "description": "Portable debug preset for Linux/macOS using system toolchain",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ]
}